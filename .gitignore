# Dependencies
node_modules/

# Build output
dist/
scripts/record-cost-event.js

# IDE
.idea/
.vscode/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Logs
*.log
npm-debug.log*

# Environment
.env
.env.local

# Python virtual environments (TLDR)
.venv/
.tldr/

# Test coverage
coverage/

# Dashboard build
src/dashboard/frontend/dist/
src/dashboard/server/dist/

# Local SSL certs (generated by mkcert)
templates/traefik/certs/
workspaces/

# Compiled TypeScript (build artifacts)
src/lib/**/*.js
# Vendored caveman hook files (JS, not compiled output)
!src/lib/caveman/*.js
src/dashboard/frontend/test-results/
src/dashboard/frontend/playwright-report/
test-results/
src/dashboard/restart.sh

# Workspace-specific generated files
CLAUDE.md

# Planning artifacts — tracked on feature branches, excluded from merges to main.
# postMergeLifecycle removes them from main programmatically (PAN-337).
# DO NOT gitignore .planning/ — agents and dashboard need these files throughout
# the workspace lifecycle. See docs/PRD-REMOTE-WORKSPACES.md §Pre-requisite.
# .planning/

# Test caches (regenerated on each run)
.cache/

# Devcontainer files (generated from .template files per-workspace)
.devcontainer/
dev
devcontainer.json
docker-compose.devcontainer.yml

# Pan sync manifest (tracks what pan sync installed — workspace-specific)
.claude/.panopticon-manifest.json
# Workspace-specific agent definitions (triage-agent etc. are local tooling)
.claude/agents/
# Review prompt templates — source of truth is src/lib/cloister/prompts/review/,
# synced to ~/.panopticon/review-prompts/ by pan sync. Must not appear in worktrees
# where work agents could read them and attempt self-review.
.claude/prompts/code-review-*.prompt-template.md
# Workspace-specific settings (absolute paths, caveman variant — must not merge to main)
.claude/settings.json
.claude/settings.local.json
.claude/.caveman-variant

# Build source maps
scripts/*.map

# Workspace node_modules symlink (points to main repo, not real content)
node_modules
src/dashboard/frontend/node_modules

# Beads — tracked on feature branches, same as .planning/.
# DO NOT gitignore — agents need these files for task tracking and the
# start-agent endpoint runs `git add .beads/` which fails if ignored.
# The review specialist requires beads completion verification before approval.
# .beads/

# Stitch temp files
temp/
.panopticon.env
.playwright-mcp/
.playwright-mcp/

# Graphify output — track reports/viz, exclude large raw data files
graphify-out/graph.json
graphify-out/cache/

# Panopticon runtime artifacts (ephemeral, not tracked)
.pan/events/
.pan/convoy/
.pan/prompts/
.panopticon/

# Beads / Dolt files (added by bd init)
.dolt/
*.db
.beads-credential-key

# Release notes generated during version bumps
.release/

# apps/desktop server bundle — regenerated by build-for-publish.mjs before publish
apps/desktop/server/
.claude/worktrees/
.claude/scheduled_tasks.lock
.pan/review/

# Sibling projects sometimes cloned into working tree (separate repos)
multica/
*.log.1
.panopticon/config.yaml
.cache/
.tldr/
.claude/mcp.json
