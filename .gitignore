# Workspace-specific generated files
CLAUDE.md

# Workspace-only vBRIEF + continue state (per the five-artifact model in CLAUDE.md).
# These files are mutated by the work agent and must never reach main — otherwise
# every new worktree inherits the last-committed workspace's spec and pan start
# refuses with "Workspace planning artifacts are for PAN-XXXX". See PAN-1073.
# The canonical lifecycle artifacts (.pan/specs/, .pan/continues/, .pan/drafts/)
# remain tracked — only the workspace working copies are excluded.
.pan/spec.vbrief.json
.pan/continue.json
.pan/kickoff.md
# Session handoff briefs (pan handoff long-form docs) are working-tree-only —
# the spawned conversation reads them from disk; auto-commit sweeps must not
# push them into PRs.
.pan/handoff-*.md
# Backlog Sequencer manifest — transient input written each pass and referenced
# from the prompt (the agent reads it instead of having it inlined). Only the
# ranked output .pan/backlog/sequence.md is canonical/tracked.
.pan/backlog/manifest.json

# Docs-index builder scratch dir (buildDocsIndex writes docs-index.*.tmp.sqlite
# here, renames the result into dist/, but never removes the dir). Transient —
# must never block the work-completion clean-tree check. See src/lib/docs/index-builder.ts.
.pan-docs-index-tmp/

# Docs-index builder scratch dir (buildDocsIndex writes docs-index.*.tmp.sqlite
# here, renames the result into dist/, but never removes the dir). Transient —
# must never block the work-completion clean-tree check. See src/lib/docs/index-builder.ts.
.pan-docs-index-tmp/

# Planning artifacts — tracked on feature branches, excluded from merges to main.
# postMergeLifecycle removes them from main programmatically (PAN-337).
# DO NOT gitignore .planning/ — agents and dashboard need these files throughout
# the workspace lifecycle. See docs/PRD-REMOTE-WORKSPACES.md §Pre-requisite.
# .planning/

# Test caches (regenerated on each run)
.cache/

# Devcontainer files (generated from .template files per-workspace)
.devcontainer/
dev
devcontainer.json
docker-compose.devcontainer.yml

# Pan sync manifest (tracks what pan sync installed — workspace-specific)
.claude/.overdeck-manifest.json
# Panopticon skill-installer manifest (tracks what panopticon sync installed — workspace-specific)
.claude/.panopticon-manifest.json
# Machine-local panopticon project registry — a leftover from the pre-rebrand
# panopticon-cli checkout. The canonical projects.yaml lives in ~/.panopticon
# (compat) and ~/.overdeck/ (canonical); neither is the repo's concern.
.panopticon/
# Workspace-specific Claude Code sync targets (local tooling, not source of truth)
.claude/agents/
.claude/skills/
# Review prompt templates — source of truth is src/lib/cloister/prompts/review/,
# synced to ~/.overdeck/review-prompts/ by pan sync. Must not appear in worktrees
# where work agents could read them and attempt self-review.
.claude/prompts/code-review-*.prompt-template.md
# Workspace-specific settings (absolute paths, caveman variant — must not merge to main)
.claude/settings.json
.claude/settings.local.json
.claude/.caveman-variant

# Build source maps
scripts/*.map

# Workspace node_modules symlink (points to main repo, not real content)
node_modules
src/dashboard/frontend/node_modules

# Beads — tracked on feature branches, same as .planning/.
# DO NOT gitignore — agents need these files for task tracking and the
# start-agent endpoint runs `git add .beads/` which fails if ignored.
# The review specialist requires beads completion verification before approval.
# .beads/

# Stitch temp files
temp/
.overdeck.env
.playwright-mcp/
.playwright-mcp/

# Overdeck runtime artifacts (ephemeral, not tracked)
.pan/events/
.pan/convoy/
.pan/prompts/
.pan/pid/
.pan/continue.json
.pan/feedback/
.pan/followup-issues.txt
.pan/spec.vbrief.json
.pan/agent-mcp.json
# Machine-local Overdeck config (config.yaml, projects.yaml, settings.json) —
# copied into workspaces by copyOverdeckSettingsToWorkspaceSync, never committed.
.overdeck/
# Spec-writer crash debris — the writer should self-clean these on dead-PID detection.
# Tracking them lets stale locks contaminate fresh worktrees.
.pan/specs/*.tmp
.pan/specs/*.writer.lock/

# Scratch/temp working dir — holds throwaway mockups, draft issue notes, and a
# machine-specific V8 node-compile-cache. Never belongs in git history.
.tmp/

# Beads / Dolt files (added by bd init)
.dolt/
*.db
.beads-credential-key

# .release/<tag>.md is the canonical release-notes artifact produced by
# `pan release stable` — it is checked in so the CI release workflow can
# read it from the tagged commit instead of regenerating from a shallow
# checkout. Keep tracked.

# apps/desktop server bundle — regenerated by build-for-publish.mjs before publish
apps/desktop/server/

# Moonshine voice sidecar — built by `pan install` (see PAN-1053 follow-ups).
# The binary and venv are environment-specific build artifacts.
packages/moonshine-linux-x64/bin/moonshine-sidecar
.moonshine-sidecar-build/
.moonshine-sidecar-venv/
.claude/worktrees/
.claude/scheduled_tasks.lock
.pan/review/

# Sibling projects sometimes cloned into working tree (separate repos)
multica/
*.log.1
.cache/
.tldr/
.claude/mcp.json

# Local junk / debugging artifacts (PAN session 2026-06-07) — never commit
__pycache__/
.beads/.~issues.jsonl.*
/.brake-salvage/
/conv-*.jpeg
/reconnect-*.jpeg
/deeplink-*.jpeg
/overdeck-feature-graph.png
/SYSTEM-RESOURCE-REPORT-*.md

# Pre-launch sensitive marketing strategy (rebrand candidates, fundraising) — keep local
/docs/marketing/private/

# Generated at Vercel build by vercel.json (cp scripts/install.sh → site/install)
/site/install

# Installed skill sync target (e.g. the `impeccable` skill) — generated, not source
/.agents/
# Test-run output logs (e2e/unit/playwright/dashboard) — generated per run
/reports/
.vercel
