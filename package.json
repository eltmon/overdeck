{
  "name": "@panctl/cli",
  "version": "0.9.1",
  "description": "Multi-agent orchestration for AI coding assistants (Claude Code, Codex, Cursor, Gemini CLI)",
  "keywords": [
    "ai-agents",
    "orchestration",
    "claude-code",
    "codex",
    "cursor",
    "gemini",
    "multi-agent",
    "devtools",
    "linear"
  ],
  "author": "Edward Becker <edward.becker@mindyournow.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/eltmon/panopticon-cli.git"
  },
  "homepage": "https://github.com/eltmon/panopticon-cli#readme",
  "bugs": {
    "url": "https://github.com/eltmon/panopticon-cli/issues"
  },
  "type": "module",
  "workspaces": {
    "packages": [
      "packages/contracts",
      "packages/pi-extension",
      "src/dashboard/server",
      "src/dashboard/frontend",
      "apps/desktop"
    ],
    "catalog": {
      "effect": "4.0.0-beta.45",
      "@effect/platform-bun": "4.0.0-beta.45",
      "@effect/platform-node": "4.0.0-beta.45",
      "@effect/sql-sqlite-bun": "4.0.0-beta.45",
      "@effect/vitest": "4.0.0-beta.45",
      "@effect/language-service": "0.84.2",
      "@types/bun": "^1.2.0",
      "typescript": "^5.7.3"
    }
  },
  "bin": {
    "panctl": "./dist/cli/index.js",
    "pan": "./dist/cli/index.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "templates",
    "skills",
    "scripts",
    "roles",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=22.0.0"
  },
  "overrides": {
    "@effect/platform-node-shared": "4.0.0-beta.45"
  },
  "scripts": {
    "dev": "tsx watch src/cli/index.ts",
    "build": "npm run build:contracts && npm run build:pi-extension && npm run build:cli && npm run build:scripts && npm run build:dashboard",
    "build:pi-extension": "npm --prefix ./packages/pi-extension run build",
    "build:cli": "node scripts/build-cli.mjs",
    "build:contracts": "node scripts/fs-helper.mjs rmrf packages/contracts/dist && npm --prefix ./packages/contracts run build",
    "build:scripts": "cd scripts && tsdown",
    "build:dashboard": "npm run build:dashboard:frontend && npm run build:dashboard:server",
    "build:dashboard:frontend": "npm --prefix ./src/dashboard/frontend run build",
    "build:dashboard:server": "npm run build:contracts && npm --prefix ./src/dashboard/server run build && node scripts/fs-helper.mjs copy-ext .md src/lib/cloister/prompts dist/dashboard/prompts",
    "build:desktop": "cd apps/desktop && bun run build && bun run dist:linux && bun run dist:mac && bun run dist:win",
    "build:desktop:linux": "cd apps/desktop && bun run build && bun run dist:linux",
    "build:desktop:mac": "cd apps/desktop && bun run build && bun run dist:mac",
    "build:desktop:win": "cd apps/desktop && bun run build && bun run dist:win",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/ && npm run lint:permissions && npm run lint:skills",
    "lint:permissions": "bash scripts/lint-permissions.sh",
    "lint:skills": "bash scripts/lint-skills.sh",
    "pretest": "npm run build:contracts",
    "test": "vitest run",
    "test:unit": "vitest run tests/unit",
    "test:integration": "vitest run tests/integration",
    "test:e2e": "vitest run tests/e2e",
    "test:coverage": "vitest run --coverage",
    "docs": "typedoc",
    "docs:watch": "typedoc --watch",
    "prepublishOnly": "npm run build",
    "postinstall": "node scripts/postinstall.mjs || true",
    "prepare": "husky"
  },
  "dependencies": {
    "@effect/platform-bun": "4.0.0-beta.45",
    "@effect/platform-node": "4.0.0-beta.45",
    "@effect/platform-node-shared": "4.0.0-beta.45",
    "@homebridge/node-pty-prebuilt-multiarch": "^0.13.1",
    "@iarna/toml": "^2.2.5",
    "@linear/sdk": "^70.0.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@octokit/rest": "^22.0.1",
    "@types/mustache": "^4.2.6",
    "@types/ws": "^8.18.1",
    "better-sqlite3": "^12.6.2",
    "chalk": "^5.6.2",
    "commander": "^12.1.0",
    "conf": "^12.0.0",
    "execa": "^8.0.1",
    "inquirer": "^9.3.8",
    "js-yaml": "^4.1.1",
    "mustache": "^4.2.0",
    "ora": "^8.2.0",
    "smee-client": "^5.0.0",
    "ws": "^8.20.0",
    "yaml": "^2.8.2"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@panctl/contracts": "workspace:*",
    "@types/better-sqlite3": "^7.6.13",
    "@types/inquirer": "^9.0.9",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.10.0",
    "@typescript-eslint/parser": "6.21.0",
    "@vitest/coverage-v8": "^4.1.6",
    "effect": "catalog:",
    "eslint": "^8.55.0",
    "husky": "^9.1.7",
    "playwright": "^1.59.1",
    "tsdown": "^0.21.7",
    "tsx": "^4.6.2",
    "typedoc": "^0.25.0",
    "typescript": "^5.3.2",
    "vitest": "^4.1.6"
  }
}
