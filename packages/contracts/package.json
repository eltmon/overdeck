{
  "name": "@overdeck/contracts",
  "version": "0.40.0",
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/eltmon/overdeck.git",
    "directory": "packages/contracts"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
