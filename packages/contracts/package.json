      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs",
      "default": "./dist/index.mjs"
    }
  },
  "scripts": {
    "dev": "tsdown --watch",
    "build": "tsdown",
    "test": "vitest run --config vitest.config.ts",
    "run": "bun run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "effect": "4.0.0-beta.73"
  },
  "devDependencies": {
    "@effect/language-service": "catalog:",
    "tsdown": "^0.21.7",
    "typescript": "catalog:"
  },
  "files": [
    "dist"
  ]
