{
  "name": "@panopticon/desktop",
  "version": "0.7.1",
  "private": true,
  "main": "dist-electron/main.js",
  "productName": "Panopticon",
  "scripts": {
    "dev": "bun run --parallel dev:bundle dev:electron",
    "dev:bundle": "tsdown --watch",
    "dev:electron": "bun run scripts/dev-electron.mjs",
    "build": "tsdown",
    "start": "bun run scripts/start-electron.mjs",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "dist:linux": "electron-builder --linux AppImage --publish never",
    "dist:mac": "electron-builder --mac dmg --universal --publish never",
    "postinstall": "electron-rebuild -f -w node-pty,better-sqlite3"
  },
  "dependencies": {
    "conf": "^13.0.0",
    "electron-updater": "^6.8.3"
  },
  "devDependencies": {
    "@panopticon/contracts": "workspace:*",
    "@types/node": "^22.0.0",
    "electron": "40.6.0",
    "electron-builder": "^25.1.8",
    "electron-rebuild": "^3.2.9",
    "tsdown": "^0.21.7",
    "typescript": "catalog:",
    "vitest": "^4.0.18"
  },
  "build": {
    "appId": "com.panopticon.app",
    "productName": "Panopticon",
    "publish": {
      "provider": "github",
      "owner": "eltmon",
      "repo": "panopticon-cli"
    },
    "files": [
      "dist-electron/**/*",
      "!dist-electron/**/*.map"
    ],
    "extraResources": [
      {
        "from": "../../dist/dashboard/server.js",
        "to": "server/server.js"
      },
      {
        "from": "../../dist/dashboard/public",
        "to": "server/public"
      },
      {
        "from": "resources",
        "to": "resources"
      }
    ],
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": ["x64"]
        }
      ],
      "icon": "resources/icon.png",
      "category": "Development"
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": ["arm64", "x64"]
        }
      ],
      "icon": "resources/icon.icns",
      "category": "public.app-category.developer-tools"
    },
    "dmg": {
      "title": "Panopticon",
      "icon": "resources/icon.icns"
    },
    "afterPack": "scripts/afterPack.cjs"
  }
}
