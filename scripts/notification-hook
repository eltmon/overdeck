#!/bin/bash
# ~/.panopticon/bin/notification-hook
# Called by Claude Code on Notification events.
#
# Investigation findings (PAN-709):
# The Notification event fires for system/desktop notifications from Claude Code
# (e.g., "Task complete", "Needs attention"). It does NOT fire for in-terminal
# tool approval dialogs (Allow tool? [y/N]) — those never trigger this hook.
# The primary waiting-on-human detection mechanisms are:
#   1. pre-tool-hook: detects AskUserQuestion tool (explicit agent question)
#   2. deacon tmux-tail scanner: detects [y/N], "Press any key", etc. in output
#
# This hook logs notification payloads for future analysis and sets
# waiting-on-human if the notification text indicates the agent needs input.

# Don't use set -e - we want the hook to be resilient to failures
# and never break Claude Code execution

# Get agent ID from env or tmux session name
if [ -n "$PANOPTICON_AGENT_ID" ]; then
  AGENT_ID="$PANOPTICON_AGENT_ID"
elif [ -n "$TMUX" ]; then
  AGENT_ID=$(tmux display-message -p '#S' 2>/dev/null)
else
  AGENT_ID="main-cli"
fi
AGENT_ID="${AGENT_ID:-unknown}"

# Parse notification info from stdin
NOTIF_INFO=$(cat 2>/dev/null || echo '{}')

# Check if jq is available
if ! command -v jq &> /dev/null; then
  exit 0
fi

# Extract notification message
NOTIF_MSG=$(echo "$NOTIF_INFO" | jq -r '.message // ""' 2>/dev/null || echo "")

# Log notification payloads for analysis (kept for 7 days worth of entries max 500)
LOG_DIR="$HOME/.panopticon/logs"
mkdir -p "$LOG_DIR"
LOG_FILE="$LOG_DIR/notifications.jsonl"
TIMESTAMP="$(date -Iseconds)"

jq -n \
  --arg ts "$TIMESTAMP" \
  --arg agent "$AGENT_ID" \
  --argjson payload "$NOTIF_INFO" \
  '{ts: $ts, agent: $agent, payload: $payload}' \
  >> "$LOG_FILE" 2>/dev/null || true

# Prune log to last 500 entries
if [ -f "$LOG_FILE" ]; then
  TEMP_LOG="$LOG_FILE.tmp"
  tail -n 500 "$LOG_FILE" > "$TEMP_LOG" 2>/dev/null && mv "$TEMP_LOG" "$LOG_FILE" 2>/dev/null || true
fi

# Check if the notification suggests the agent is waiting for human input.
# Pattern: messages containing "approval", "waiting", "permission", or "input needed"
# (these keywords help catch future notification types we haven't seen yet)
WAITING=false
if echo "$NOTIF_MSG" | grep -qiE '(approval|waiting for|permission|input needed|needs your)'; then
  WAITING=true
fi

if [ "$WAITING" = "true" ]; then
  STATE_DIR="$HOME/.panopticon/agents/$AGENT_ID"
  mkdir -p "$STATE_DIR"
  RUNTIME_FILE="$STATE_DIR/runtime.json"
  TEMP_FILE="$STATE_DIR/runtime.json.tmp"

  if [ -f "$RUNTIME_FILE" ]; then
    jq --arg ts "$TIMESTAMP" --arg reason "notification" --arg msg "$NOTIF_MSG" \
      '.state = "waiting-on-human" | .waitingReason = $reason | .waitingStartedAt = $ts | .waitingNotification = $msg' \
      "$RUNTIME_FILE" > "$TEMP_FILE" 2>/dev/null && mv "$TEMP_FILE" "$RUNTIME_FILE" 2>/dev/null || true
  fi
fi

# Always exit successfully
exit 0
