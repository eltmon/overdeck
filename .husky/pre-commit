#!/bin/sh
# Pre-commit guard: block manual edits to package.json `"version"` fields
# unless this is a release commit produced by `pan release stable`.
#
# Why: a manual version bump in one package.json (without bumping the other
# two AND committing .release/<tag>.md AND tagging) is a silent failure mode
# — the commit pushes, CI publishes nothing new but appears to succeed
# (see v0.9.0 incident). `pan release stable` is the only correct path.
#
# Bypass with `git commit --no-verify` if you really know what you're doing.

set -e

# Check the index — what's actually about to be committed.
staged_pkg_changes=$(git diff --cached --name-only | grep -E '(^|/)package\.json$' || true)

if [ -z "$staged_pkg_changes" ]; then
  exit 0
fi

# Only blocks when the staged diff includes a "version": field change.
# Pure dep / script edits to package.json are allowed.
version_changed=0
for pkg in $staged_pkg_changes; do
  if git diff --cached -U0 "$pkg" | grep -E '^[-+]\s*"version"\s*:' >/dev/null; then
    version_changed=1
    break
  fi
done

if [ "$version_changed" -eq 0 ]; then
  exit 0
fi

# Read the commit message. Husky places it at .git/COMMIT_EDITMSG before
# the commit-msg hook fires; that's the source of truth for what's about
# to land. The release tooling uses the canonical subject below.
msg_file=".git/COMMIT_EDITMSG"
if [ ! -f "$msg_file" ]; then
  # Some flows (rebase, cherry-pick) skip the editor — accept those, the
  # commit-msg or push hook can still catch malformed releases.
  exit 0
fi

first_line=$(head -n 1 "$msg_file")
if echo "$first_line" | grep -Eq '^chore: release [0-9]+\.[0-9]+\.[0-9]+(-canary\.[0-9]+)?$'; then
  exit 0
fi

cat >&2 <<EOF

Refusing to commit a package.json version change outside of \`pan release stable\`.

Detected version field changes staged in:
$(echo "$staged_pkg_changes" | sed 's/^/  /')

Commit subject: $first_line

If this is a release, abort and run:

  pan release stable --version X.Y.Z

If you're editing dependencies or scripts and the version diff is unintended,
unstage the version line:

  git restore --staged package.json   # then edit out the version change

If you're sure this is correct and you want to override, re-run with:

  git commit --no-verify

(but be aware the pre-push hook and CI release guard will still reject the
resulting tag if package.json versions and .release/<tag>.md aren't aligned.)

EOF
exit 1
