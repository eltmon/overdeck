{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": null,
  "installCommand": "true",
  "buildCommand": "cp scripts/install.sh site/install",
  "outputDirectory": "site",
  "redirects": [
    {
      "source": "/docs",
      "destination": "https://docs.overdeck.ai",
      "permanent": true
    },
    {
      "source": "/docs/:path*",
      "destination": "https://docs.overdeck.ai/:path*",
      "permanent": true
    }
  ],
  "headers": [
    {
      "source": "/install",
      "headers": [
        { "key": "content-type", "value": "text/plain; charset=utf-8" }
      ]
    }
  ]
}
